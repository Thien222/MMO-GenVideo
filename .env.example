# Copy file nay thanh ".env" roi dien key thuc cua ban vao.
# Lay Groq key (bat buoc): https://console.groq.com  -> API Keys -> Create
GROQ_API_KEY=your_groq_key_here

# Lay Pexels key (bat buoc cho B-roll English shorts): https://www.pexels.com/api
PEXELS_API_KEY=your_pexels_key_here

# (TUY CHON) Token Pollinations - dang ky FREE tai https://auth.pollinations.ai
# Co token: tai hinh whiteboard nhanh hon ~3 lan + bo watermark. De trong cung chay duoc.
POLLINATIONS_TOKEN=your_pollinations_token_here
